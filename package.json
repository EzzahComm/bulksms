{
  "name": "ezzahcomm-bulk-sms",
  "version": "1.0.0",
  "description": "EZZAHCOMM Bulk SMS — billing/provisioning/compliance control plane over the TextSMS gateway",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch --env-file=.env src/server.js",
    "lint": "eslint src",
    "docker:build": "docker build -t ezzahcomm-bulk-sms:latest .",
    "docker:run": "docker run -p 3003:3003 --env-file .env ezzahcomm-bulk-sms:latest"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.47.0",
    "axios": "^1.7.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^8.0.0",
    "pino": "^9.0.0",
    "pino-http": "^10.0.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "globals": "^15.0.0"
  },
  "engines": {
    "node": ">=20.6.0"
  }
}
