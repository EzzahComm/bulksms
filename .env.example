# ============================================================================
# EZZAHCOMM BULK SMS — Gateway / Control-plane configuration
# ============================================================================

# --- Server ---
NODE_ENV=development
PORT=3003
SERVICE_NAME=ezzahcomm-bulk-sms
LOG_LEVEL=info
# Comma-separated list of allowed CORS origins (the dashboard SPA, marketing site)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Supabase (NEXUS shared project) ---
SUPABASE_URL=https://skwgfymxyjtlxmauyidn.supabase.co
SUPABASE_KEY=your-anon-key                 # anon key (used only to verify user JWTs)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # service role (backend DB access)

# This Nexus tenant's id (EZZAHCOMM BULK SMS). Override only if it changes.
EZZAHCOMM_TENANT_ID=e2200000-0000-4000-8000-000000000001

# --- Credit economics ---
CREDIT_PRICE_KES=1            # KES paid per 1 SMS credit (top-up conversion)
CREDITS_PER_SEGMENT=1         # credits charged per 160-char (GSM) segment

# --- SMS gateway (TextSMS / Advanta Africa — identical API) ---
# Leave keys blank (or set SMS_DRY_RUN=true) to simulate sends.
SMS_DRY_RUN=true
# Provider selects the default base host: textsms | advanta
SMS_PROVIDER=textsms
# Optional explicit host override (else derived from SMS_PROVIDER):
#   textsms -> https://sms.textsms.co.ke
#   advanta -> https://quicksms.advantasms.com
SMS_BASE_URL=
# Credentials from your provider dashboard:
SMS_API_KEY=
SMS_PARTNER_ID=
SMS_SENDER_ID=EZZAH           # approved sender id / shortcode
#
# Legacy aliases — still honoured when the SMS_* vars above are unset:
# TEXTSMS_BASE_URL=https://sms.textsms.co.ke
# TEXTSMS_API_KEY=
# TEXTSMS_PARTNER_ID=
# TEXTSMS_SHORTCODE=EZZAH

# --- M-Pesa Daraja ---
# Leave credentials blank (or set MPESA_DRY_RUN=true) to simulate STK push.
MPESA_DRY_RUN=true
MPESA_ENV=sandbox             # sandbox | production
# MPESA_BASE_URL is auto-derived from MPESA_ENV; override only if needed.
MPESA_BASE_URL=
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_TRANSACTION_TYPE=CustomerPayBillOnline   # or CustomerBuyGoodsOnline (till)
MPESA_CALLBACK_URL=https://your-domain/webhooks/mpesa

# --- Rate limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=300

# --- API keys ---
API_KEY_PREFIX=ezk_live_
